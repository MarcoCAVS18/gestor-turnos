rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin role via custom claim (set server-side with the Admin SDK; the
    // client cannot forge it). Gates the moderation/admin panel.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Users collection - SECURED
    // Each user can only read/write their own profile
    // CRITICAL: subscription field is protected from client-side manipulation
    // Only Cloud Functions (admin SDK) can set isPremium: true.
    // liveModeUsage is constrained so free users cannot reset their monthly counter:
    // every write must use serverTimestamp() for lastResetDate (prevents backdating),
    // and monthlyCount can only be incremented by 1 or reset to 0 on a real month change.
    match /users/{userId} {

      function isValidLiveModeUsageChange() {
        let newUsage = request.resource.data.liveModeUsage;
        return newUsage.monthlyCount is int
          && newUsage.lastResetDate == request.time
          && (
            // First write (field didn't exist yet): init (0) or first session (1)
            (!('liveModeUsage' in resource.data)
              && newUsage.monthlyCount >= 0 && newUsage.monthlyCount <= 1)
            ||
            // Increment by exactly 1
            ('liveModeUsage' in resource.data
              && newUsage.monthlyCount == resource.data.liveModeUsage.monthlyCount + 1)
            ||
            // Monthly reset: only to 0, and only when the stored timestamp is from
            // a different month/year (or missing/invalid)
            ('liveModeUsage' in resource.data
              && newUsage.monthlyCount == 0
              && (
                !(resource.data.liveModeUsage.lastResetDate is timestamp)
                || resource.data.liveModeUsage.lastResetDate.month() != request.time.month()
                || resource.data.liveModeUsage.lastResetDate.year() != request.time.year()
              ))
          );
      }

      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // Create: subscription must NOT be premium, usage counter must start at 0,
      // and server-managed flags cannot be set by the client
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && (!('subscription' in request.resource.data)
                        || request.resource.data.subscription.isPremium == false)
                    && (!('liveModeUsage' in request.resource.data)
                        || request.resource.data.liveModeUsage.monthlyCount == 0)
                    && !request.resource.data.keys().hasAny(['isPremiumTest', 'calendarToken']);

      // Update: block subscription changes unless setting isPremium to false,
      // block server-managed flags, and constrain liveModeUsage changes
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['isPremiumTest', 'calendarToken'])
                    && (
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription'])
                      || request.resource.data.subscription.isPremium == false
                    )
                    && (
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['liveModeUsage'])
                      || isValidLiveModeUsageChange()
                    );

      // Delete: only own account
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Private subcollection for sensitive data (OAuth tokens, etc.)
      // Only accessible by Cloud Functions (server-side)
      match /private/{document=**} {
        allow read, write: if false; // Client cannot access, only Cloud Functions
      }
    }

    // Works collection
    match /works/{workId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Shifts collection
    match /shifts/{shiftId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Payslips collection (datos extraídos de recibos cargados por el usuario)
    match /payslips/{payslipId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Live Sessions collection (for Live Mode feature)
    // read allows null resource so that transactions can check the lock doc before it exists
    match /liveSessions/{sessionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Shared works collection - SECURED
    // Only publicly accessible if explicitly marked as public
    match /shared_works/{sharedWorkId} {
      allow read: if resource.data.isPublic == true; // Only if marked public
      allow create: if request.auth != null
                    && request.resource.data.sharedBy == request.auth.uid
                    && request.resource.data.isPublic is bool; // Require isPublic field
      // Owner can update anything; any authenticated user can only increment usesCount
      // on a public document (needed when accepting a shared work link).
      allow update: if request.auth != null && (
                      resource.data.sharedBy == request.auth.uid ||
                      (resource.data.isPublic == true &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usesCount']) &&
                       request.resource.data.usesCount == resource.data.usesCount + 1)
                    );
      allow delete: if request.auth != null && resource.data.sharedBy == request.auth.uid;
    }

    // Feedback collection
    // Anyone can read approved feedback (for the carousel)
    // Users can read/write their own feedback
    match /feedback/{feedbackId} {
      // Anyone (even unauthenticated) can read approved feedback
      allow read: if resource.data.status == 'approved';
      // Authenticated users can read their own feedback (any status)
      allow read: if request.auth != null && feedbackId == request.auth.uid;
      // Admins can read every review (moderation panel) and change its status
      allow read, update: if isAdmin();
      // Users can only create/update their own feedback
      allow create, update: if request.auth != null && feedbackId == request.auth.uid;
      allow delete: if false;
    }

    // OAuth state tokens - server-managed (Cloud Functions only)
    match /oauth_states/{stateId} {
      allow read, write: if false;
    }

    // Processed webhook events - server-managed (Cloud Functions only)
    match /processed_webhooks/{eventId} {
      allow read, write: if false;
    }

    // Rate limiting documents - server-managed (Cloud Functions only)
    match /rate_limits/{limitId} {
      allow read, write: if false;
    }

    // Subscription lock documents - server-managed (Cloud Functions only)
    match /subscription_locks/{lockId} {
      allow read, write: if false;
    }

    // Trial usage records - server-managed (Cloud Functions only)
    // Persists across "Clear Everything" to prevent trial abuse.
    // Client can read their own record to show correct UI, but can NEVER write.
    match /trial_records/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }
  }
}
